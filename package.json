{
  "name": "conferia",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "CONFERIA - Anonymous Campus Community Social Platform",
  "author": "Conferia Team",
  "license": "MIT",
  "homepage": "https://conferia.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/conferia/conferia-app"
  },
  "bugs": {
    "url": "https://github.com/conferia/conferia-app/issues"
  },
  "keywords": [
    "anonymous",
    "social-media",
    "college",
    "campus",
    "confession",
    "community",
    "react",
    "vite",
    "firebase"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "build:staging": "vite build --mode staging",
    "preview": "vite preview",
    "preview:prod": "vite preview --mode production",
    "start": "vite",
    "serve": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext js,jsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css,json,md}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "analyze": "vite-bundle-analyzer",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.vite",
    "reset": "rm -rf node_modules package-lock.json && npm install",
    "prepare": "husky install",
    "postinstall": "husky install",
    "pre-commit": "lint-staged",
    "deploy": "npm run build && firebase deploy",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "deploy:functions": "firebase deploy --only functions",
    "firebase:emulators": "firebase emulators:start",
    "generate": "plop",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "firebase": "^10.7.0",
    "date-fns": "^3.0.0",
    "react-hot-toast": "^2.4.1",
    "framer-motion": "^10.16.0",
    "react-icons": "^4.12.0",
    "uuid": "^9.0.0",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.0.8",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.32",
    "autoprefixer": "^10.4.16",
    "postcss-import": "^16.0.0",
    "postcss-nested": "^6.0.1",
    "postcss-preset-env": "^9.3.0",
    "postcss-simple-vars": "^7.0.1",
    "postcss-mixins": "^9.0.4",
    "postcss-url": "^10.1.3",
    "postcss-extend-rule": "^4.0.0",
    "postcss-reporter": "^7.0.5",
    "postcss-scss": "^4.0.9",
    "cssnano": "^6.0.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "eslint": "^8.55.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-import": "^2.29.0",
    "prettier": "^3.1.0",
    "prettier-plugin-tailwindcss": "^0.5.9",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "vitest": "^1.1.0",
    "@vitest/ui": "^1.1.0",
    "@vitest/coverage-v8": "^1.1.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/user-event": "^14.5.1",
    "jsdom": "^23.0.1",
    "@playwright/test": "^1.40.1",
    "vite-bundle-analyzer": "^0.6.0",
    "storybook": "^7.6.4",
    "@storybook/react": "^7.6.4",
    "@storybook/react-vite": "^7.6.4",
    "@storybook/addon-essentials": "^7.6.4",
    "@storybook/addon-interactions": "^7.6.4",
    "@storybook/addon-links": "^7.6.4",
    "@storybook/addon-a11y": "^7.6.4",
    "plop": "^4.0.0",
    "typescript": "^5.3.3",
    "babel-plugin-transform-remove-console": "^6.9.4"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,md,json}": [
      "prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "last 2 versions",
      "Firefox ESR",
      "not dead",
      "not op_mini all",
      "iOS >= 14",
      "Android >= 10"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "npm@10.0.0"
}